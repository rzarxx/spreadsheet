// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model SheetConfig {
  id           String   @id @default(cuid())
  token        String   @unique
  clientEmail  String
  privateKey   String
  sheetId      String
  headerRow    Int      @default(1)
  startColumn  String   @default("A")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}
